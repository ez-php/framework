{
  "name": "ez-php/framework",
  "version": "1.0.0",
  "description": "Lightweight PHP framework core — dependency injection, routing, middleware, and database migrations",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["framework", "dependency-injection", "routing", "middleware", "migration", "php"],
  "homepage": "https://github.com/ez-php/framework",
  "support": {
    "issues": "https://github.com/ez-php/framework/issues",
    "source": "https://github.com/ez-php/framework"
  },
  "require": {
    "php": "^8.5",
    "ext-pdo": "*",
    "ez-php/contracts": "*",
    "ez-php/dotenv": "*",
    "ez-php/http": "*",
    "ez-php/console": "*",
    "ez-php/i18n": "*",
    "ez-php/validation": "*"
  },
  "require-dev": {
    "ez-php/docker": "*",
    "ez-php/testing-application": "*",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
